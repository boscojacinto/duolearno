GEMINI_API_KEY=your-api-key-here
GOOGLE_API_KEY=your-api-key-here   # same value as GEMINI_API_KEY, used by CopilotKit BuiltInAgent

# Redis — required. Backs Mastra workflow-run snapshots and quiz-session memory.
REDIS_URL=redis://localhost:6379

# PostgreSQL — required. Durable system of record for analyses and quiz results
# (tables are created automatically on first use; see db/schema.sql).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/duolearno

# Optional. Opt out of CopilotKit's anonymous telemetry (silences the runtime notice).
COPILOTKIT_TELEMETRY_DISABLED=true
